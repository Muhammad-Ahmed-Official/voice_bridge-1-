{
  "expo": {
    "name": "Voice-bridge",
    "slug": "Voice-bridge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "voicebridge",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "Voice Bridge uses Bluetooth to connect AirPods and audio devices for calls.",
        "NSBluetoothPeripheralUsageDescription": "Voice Bridge uses Bluetooth to connect AirPods and audio devices for calls."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.axplicit.voicebridge",
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "https://fonts.gstatic.com/s/notonasblearabic/v13/nwpStLG2swzX1s0-AaFeEL1o2cLSYdHkYfp47jK3ydVIIwA.woff2",
            "https://fonts.gstatic.com/s/notosansarabic/v14/nwpStLG2swzX1s0-AaFeEL1o2cLSYdHkYfp47jK3ydVIIwA.woff2"
          ]
        }
      ],
      "expo-image",
      "expo-web-browser",
      "expo-asset",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cffe30f8-c66f-4e43-86c5-3a55c34e6714"
      }
    }
  }
}
