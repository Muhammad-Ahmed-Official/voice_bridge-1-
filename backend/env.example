# ===== Translation Configuration =====
GOOGLE_API_KEY_TRANSLATION=your_google_cloud_translation_api_key_here

# ===== STT (Speech-to-Text) Configuration =====
# All confidence thresholds (0 to 1, where 1 = 100% confidence)
STT_CONFIDENCE_HIGH=0.85
STT_CONFIDENCE_MEDIUM=0.70
STT_CONFIDENCE_LOW=0.50
STT_CONFIDENCE_VERY_LOW=0

# Provider-specific thresholds
GOOGLE_STT_THRESHOLD=0.85

# Retry configuration
STT_MAX_RETRIES=3
STT_BACKOFF_MS=500

# Language-specific adjustments
# How much to adjust confidence for each language
# Urdu/Arabic are harder to recognize, so we reduce confidence
URDU_CONFIDENCE_ADJUSTMENT=-0.15
ARABIC_CONFIDENCE_ADJUSTMENT=-0.15
ENGLISH_CONFIDENCE_ADJUSTMENT=0

# Enable validation for Urdu/Arabic (checks if recognized words appear in text)
URDU_ENABLE_VALIDATION=false
ARABIC_ENABLE_VALIDATION=false

# Urdu/Arabic validation words (JSON array) - used if validation enabled
# Default includes: proper Urdu words + common English code-switching words
# (Karachi people mix Urdu with English - app handles this automatically)
# Only override if you want custom words
# Example: '[\"السلام\", \"کیسے\", \"hello\", \"okay\"]'
# Leave empty to use defaults from config
URDU_COMMON_WORDS=
ARABIC_COMMON_WORDS=

# Text analysis for confidence estimation
STT_MIN_LENGTH_HIGH_CONFIDENCE=20
STT_MIN_LENGTH_ACCEPTABLE=3
STT_LENGTH_BONUS_THRESHOLD=100
STT_LENGTH_CONFIDENCE_BONUS=0.15

# Audio analysis for confidence estimation
STT_CHARS_PER_SECOND=5
STT_RUSHED_RATIO=0.8
STT_CLEAR_RATIO=1.5
STT_RUSHED_PENALTY=-0.15
STT_CLEAR_BONUS=0.1







